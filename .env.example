# AffiliateAI Studio — env var template.
# Copy to .env.local and fill in real values. .env.local is gitignored.
# Real secrets are configured in the Vercel dashboard for production.

# ============================================================
# Supabase (https://supabase.com/dashboard/project/_/settings/api)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# OpenCode Zen (AI Text generation — free tier)
# https://opencode.ai/zen
# ============================================================
OPENCODE_API_KEY=

# ============================================================
# HuggingFace (Image-to-Text — BLIP-2 free inference)
# https://huggingface.co/settings/tokens
# ============================================================
HUGGINGFACE_API_KEY=

# ============================================================
# Optional: Kimchi.dev (backup AI provider)
# ============================================================
KIMCHI_API_KEY=

# ============================================================
# Google Analytics (configured in deployment phase)
# ============================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=
